FROM node:22-slim

WORKDIR /app

COPY package*.json tsconfig.json index.ts ./

RUN npm install && \
    # index.ts lives at root, not src/; patch the tsconfig before building
    node -e "const fs=require('fs'); \
      const t=JSON.parse(fs.readFileSync('tsconfig.json','utf8')); \
      t.compilerOptions.rootDir='.'; t.include=['index.ts']; \
      fs.writeFileSync('tsconfig.json',JSON.stringify(t,null,2));" && \
    npm run build && \
    npm prune --omit=dev

CMD ["node", "dist/index.js"]
